generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("USER") // USER, ADMIN
  avatar    String?  // Profile picture URL
  banner    String?  // Profile banner URL
  bio       String?  // User bio/description
  isVerified Boolean  @default(false)
  emailVerified Boolean @default(false)
  verificationToken String?
  verificationTokenExpires DateTime?
  kycStatus  String   @default("PENDING") // PENDING, APPROVED, REJECTED
  idDocumentUrl String?
  paymentVerified Boolean @default(false)
  stripeCustomerId String?
  paypalPayerId String?
  phone     String?
  phoneVerified Boolean @default(false)
  companyName String?
  plan      String   @default("FREE")  // FREE, PRO, PREMIUM, ENTERPRISE
  // Two-Factor Authentication
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret String?
  twoFactorBackupCodes String? // JSON string of hashed backup codes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores         Store[]
  searches       SearchHistory[]
  sellerAccounts SellerAccount[]
  sellerFollowers SellerFollower[] @relation("UserFollowers")
  following      SellerFollower[] @relation("UserFollowing")
}

model SearchHistory {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Store {
  id          String   @id @default(uuid())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  name        String
  slug        String   @unique
  description String?
  themeColor  String?  @default("indigo")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  settings    String?    // StoreSettings as JSON
  
  products    Product[]
  orders      Order[]
  customers   Customer[]
  blogPosts   BlogPost[]
  pages       Page[]
  subscribers Subscriber[]
  chatSessions ChatSession[]
  discounts   DiscountCode[]
  messages    Message[]
  activityLog ActivityLog[]
  carts           Cart[]
  moderationFlags ModerationFlag[]
  followers       SellerFollower[]
  followerAnalytics FollowerAnalytics[]
  sellerTier      SellerTier?
  topSeller       TopSeller?
}

model Cart {
  id        String   @id @default(uuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId    String?
  email     String?
  items     String       // Serialized CartItem[]
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Product {
  id          String        @id @default(uuid())
  storeId     String
  store       Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name        String
  description String?
  category    String?
  status      String        @default("ACTIVE") // ACTIVE, DRAFT, ARCHIVED
  price       Float
  compareAtPrice Float?
  costPerItem Float?
  stock       Int           @default(0)
  sku         String?
  barcode     String?
  trackQuantity Boolean     @default(true)
  images      String        // Comma-separated or JSON serialized string
  isFeatured  Boolean       @default(false)
  isDigital   Boolean       @default(false)
  variants    String?       // Serialized ProductVariant[]
  
  // Inventory Type: OWN = Seller's warehouse (Mera Maal), VIRTUAL = Dropshipped
  inventoryType   String        @default("OWN") // OWN, VIRTUAL
  originalProductId String?      // If VIRTUAL, reference to original product
  originalStoreId String?       // Store where product is sourced from
  commissionRate  Float        @default(0.05) // 5% commission for OWN inventory
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  reviews     Review[]
  orderItems  OrderItem[]
}

model Order {
  id          String      @id @default(uuid())
  storeId     String
  store       Store       @relation(fields: [storeId], references: [id])
  customerId  String?
  customer    Customer?   @relation(fields: [customerId], references: [id])
  
  // Snapshot of customer details at time of order
  customerName String
  customerEmail String
  shippingAddress String?

  subtotal    Float
  tax         Float
  shipping    Float
  discount    Float
  total       Float
  
  status      String      @default("PENDING") // PENDING, PROCESSING, SHIPPED, DELIVERED, CANCELLED, REFUNDED
  paymentStatus String    @default("PENDING") // PAID, PENDING, REFUNDED, FAILED
  fulfillmentStatus String @default("UNFULFILLED") // UNFULFILLED, PARTIAL, FULFILLED
  
  items       OrderItem[]
  timeline    String?       // Serialized OrderTimelineEntry[]
  date        DateTime    @default(now())
  
  disputes    Dispute[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  
  name      String  // Keep name in case product is deleted
  price     Float
  quantity  Int
}

model Customer {
  id            String   @id @default(uuid())
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id])
  email         String
  name          String
  phone         String?
  city          String?
  country       String?
  totalSpent    Float    @default(0)
  ordersCount   Int      @default(0)
  lastOrderDate DateTime?
  notes         String?
  tags          String?  // Serialized Tags
  wishlist      String?  // Serialized Product IDs

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  orders        Order[]

  @@unique([storeId, email])
}

model Review {
  id        String   @id @default(uuid())
  orderId   String?
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyerId   String?
  sellerId  String?
  rating    Int      // 1-5 stars
  title     String?
  content   String?
  isVerifiedPurchase Boolean @default(false)
  customerName String?
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SellerRating {
  id          String   @id @default(uuid())
  sellerId    String
  buyerId     String
  rating      Int
  category    String   // communication, shipping, product_accuracy
  comment     String?
  createdAt   DateTime @default(now())
}

// Enhanced Feedback System
model Feedback {
  id          String   @id @default(uuid())
  type        String   // PRODUCT, SELLER, PLATFORM, SHIPPING, CUSTOMER_SERVICE
  targetId    String   // productId, sellerId, orderId
  userId      String
  rating      Int      // 1-5 stars
  category    String?  // For sellers: communication, shipping, product_quality, overall
  title       String?
  content     String
  pros        String?  // What was good
  cons        String?  // What could improve
  images      String?  // Image URLs (JSON array)
  isVerified  Boolean  @default(false)
  helpfulCount Int     @default(0)  // Count of helpful votes
  status      String   @default("PUBLISHED") // DRAFT, PUBLISHED, FLAGGED, DELETED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  responses   FeedbackResponse[]
  votes       FeedbackVote[]

  @@index([type, targetId])
  @@index([userId])
  @@index([status])
}

model FeedbackResponse {
  id          String   @id @default(uuid())
  feedbackId  String
  feedback    Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  userId      String   // Seller or support response
  userName    String?  // Name of responder
  content     String
  createdAt   DateTime @default(now())

  @@index([feedbackId])
}

model FeedbackVote {
  id          String   @id @default(uuid())
  feedbackId  String
  feedback    Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  userId      String
  vote        Int      // 1 = helpful, -1 = not helpful
  createdAt   DateTime @default(now())

  @@unique([feedbackId, userId]) // One vote per user per feedback
  @@index([feedbackId])
}

model BlogPost {
  id          String   @id @default(uuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  title       String
  slug        String
  content     String
  excerpt     String?
  imageUrl    String?
  author      String?
  status      String   @default("DRAFT") // PUBLISHED, DRAFT
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Page {
  id          String   @id @default(uuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  title       String
  slug        String
  content     String
  isVisible   Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

model Subscriber {
  id        String   @id @default(uuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  email     String
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(uuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model DiscountCode {
  id        String   @id @default(uuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  code      String
  type      String   // PERCENTAGE, FIXED
  value     Float
  usageCount Int     @default(0)
  active    Boolean  @default(true)
}

model ActivityLog {
  id        String   @id @default(uuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  action    String
  details   String
  createdAt DateTime @default(now())
}

model ChatSession {
  id           String      @id @default(uuid())
  storeId      String
  store        Store       @relation(fields: [storeId], references: [id])
  customerId   String
  customerName String
  messages     ChatMessage[]
  lastMessage  String?
  unreadAdmin  Int         @default(0)
  unreadUser   Int         @default(0)
  updatedAt    DateTime    @updatedAt
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id])
  sender    String      // user, admin
  content   String
  productId String?
  createdAt DateTime    @default(now())
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GlobalSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model PlatformLog {
  id          String   @id @default(uuid())
  level       String   @default("INFO") // INFO, WARN, ERROR
  message     String
  source      String
  details     String?  // Serialized JSON
  timestamp   DateTime @default(now())
}

model ApiKey {
  id          String   @id @default(uuid())
  name        String
  key         String   @unique
  permissions String?  // Serialized Permissions
  lastUsed    DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
}

// Stripe Connect Models for Multi-Vendor Marketplace
model SellerAccount {
  id               String   @id @default(uuid())
  userId           String
  stripeAccountId  String   @unique  // Connect account ID
  chargesEnabled   Boolean  @default(false)
  payoutsEnabled   Boolean  @default(false)
  detailsSubmitted Boolean  @default(false)
  commissionRate   Float    @default(0.05)  // 5% default
  planTier         String   @default("FREE")  // FREE, PRO
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  user         User          @relation(fields: [userId], references: [id])
  commissions  Commission[]
  
  @@index([userId])
}

model Commission {
  id                String           @id @default(uuid())
  orderId           String
  sellerId          String
  seller            SellerAccount    @relation(fields: [sellerId], references: [id])
  amount            Float            // Total order amount
  commission        Float            // Platform takes
  sellerPayout      Float            // Seller receives
  status            String           @default("PENDING") // PENDING, PAID, FAILED, CANCELLED
  stripeTransferId  String?
  stripeChargeId    String?
  createdAt         DateTime         @default(now())
  paidAt            DateTime?
  
  @@index([sellerId])
  @@index([orderId])
}

// Content Moderation Models
model ModerationFlag {
  id            String   @id @default(uuid())
  productId     String
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id])
  productName   String
  productCategory String?
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED, FLAGGED
  flags         String   // Serialized string[] of flags
  confidence    Float    @default(0)
  category      String?
  moderatorNote String?
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([productId])
  @@index([storeId])
  @@index([status])
}

model ModerationLog {
  id            String   @id @default(uuid())
  action        String   // PRODUCT_CHECKED, PRODUCT_APPROVED, PRODUCT_REJECTED
  productId     String?
  storeId       String?
  moderatorId   String?
  details       String?  // JSON serialized details
  createdAt     DateTime @default(now())
  
  @@index([productId])
  @@index([moderatorId])
}

// Dispute Resolution Models
model Dispute {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  buyerId     String
  sellerId    String
  reason      String   // not_received, not_as_described, damaged, other
  description String
  status      String   @default("OPEN") // OPEN, UNDER_REVIEW, RESOLVED, CLOSED
  resolution  String?
  refundAmount Float?
  sellerResponse String?
  evidenceUrls String?  // JSON array of evidence URLs
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?
  
  @@index([buyerId])
  @@index([sellerId])
  @@index([orderId])
  @@index([status])
}

// Platform-wide Promo Codes for Subscriptions
model PromoCode {
  id          String    @id @default(uuid())
  code        String    @unique
  description String?
  discountType String   // PERCENTAGE, FIXED
  discountValue Float   // Percentage (0-100) or fixed amount
  minPurchase Float?    // Minimum purchase amount required
  maxUses     Int?      // Maximum total uses (null = unlimited)
  usedCount   Int       @default(0)
  maxUsesPerUser Int?   // Maximum uses per user
  startsAt    DateTime  @default(now())
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  applicablePlans String // JSON array of plan tiers this code applies to ["STARTER", "PRO", etc]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  usage       PromoCodeUsage[]
}

model PromoCodeUsage {
  id          String    @id @default(uuid())
  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  userId      String
  storeId     String?
  tier        String    // Plan tier purchased
  discountAmount Float   // Actual discount applied
  createdAt   DateTime  @default(now())
  
  @@index([promoCodeId])
  @@index([userId])
}

// Seller Follower System Models

// Users can follow sellers (stores)
model SellerFollower {
  id          String   @id @default(uuid())
  followerId  String   // User who is following
  follower    User     @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String   // User being followed (seller/store owner)
  following   User     @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)
  storeId     String   // Store/Seller being followed
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  
  // Unique constraint - a user can only follow a store once
  @@unique([followerId, storeId])
  @@index([storeId])
  @@index([followerId])
}

// Track follower analytics over time
model FollowerAnalytics {
  id              String   @id @default(uuid())
  storeId         String
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  date            DateTime @default(now())
  totalFollowers  Int      @default(0)
  newFollowers    Int      @default(0)
  unfollowers      Int      @default(0)
  
  @@unique([storeId, date])
  @@index([storeId])
}

// Seller tier based on subscriber count
model SellerTier {
  id                  String   @id @default(uuid())
  storeId             String   @unique
  store               Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  tierLevel           String   @default("TIER_1") // TIER_1, TIER_2, TIER_3, TIER_4
  subscriberCount     Int      @default(0)
  trustScore         Float    @default(0.0)
  retentionRate      Float    @default(0.0)
  lastUpdated        DateTime @default(now())
  
  // Tier benefits as JSON
  features            String?  // Serialized features enabled for this tier
}

// Top seller rankings cache
model TopSeller {
  id              String   @id @default(uuid())
  storeId         String   @unique
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  rank            Int      // 1 = top seller
  trustScore      Float    @default(0.0)
  followerCount   Int      @default(0)
  retentionRate   Float    @default(0.0)
  salesVolume     Float    @default(0.0)
  rating          Float    @default(0.0)
  updatedAt       DateTime @default(now())
  
  @@index([rank])
}
